# Copiá este archivo a .env y completá tus valores (NO commitees .env).

# OpenAI — curado/resumen del digest
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Resend — envío de email
RESEND_API_KEY=re_...

# Direcciones (el "from" debe usar un dominio verificado en Resend;
# para probar usá el sandbox onboarding@resend.dev)
MAIL_FROM=AI Digest <onboarding@resend.dev>
MAIL_TO=ezeuropa@hotmail.com

# Notion — panel de fuentes (OPCIONAL). Si los dejás vacíos, el digest usa
# solo las fuentes de config.py.
NOTION_TOKEN=ntn_...
NOTION_SOURCES_DB=...id_de_la_base...
